# Redis connection string (ioredis URL). Used for room state, pub/sub fan-out,
# presence, and sliding TTL. Pull from Vercel with `vercel env pull .env.local`.
#
# NOTE: This may be a Redis instance shared with other apps. All keys written by
# watchparty are namespaced under the `wp:` prefix to avoid collisions.
REDIS_URL="redis://default:password@host:port"
